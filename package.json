{
  "name": "stasium",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build ./index.ts --compile --outfile ./dist/stasium",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test",
    "init:hooks": "bun ./scripts/install-githooks.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.6.4",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.79"
  }
}
